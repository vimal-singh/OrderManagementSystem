{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "System": "Error"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "OrderSystemConnectionString": "Server=localhost;Database=OrderManagementSystemDb;User Id=SA;Password=KeysightMay@24;Encrypt=true;TrustServerCertificate=True"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Error",
        "System": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Async",

        "Args": {
          "configure": [
            {
              "Name": "Console",
              "Args": {
                "restrictedToMinimumLevel": "Debug",
                "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] [{Application}/{Server}] [CorrelationId: {CorrelationId}] {Message:lj}{NewLine}{Exception}"
              }
            },
            {
              "Name": "File",
              "Args": {
                "restrictedToMinimumLevel": "Information",

                "path": "Logs/OrderManagementAPI-.txt",

                "rollingInterval": "Day",
                "retainedFileCountLimit": 30,

                "fileSizeLimitBytes": 10485760,
                "rollOnFileSizeLimit": true,
                "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] [{Application}/{Server}] [CorrelationId: {CorrelationId}] [{SourceContext}] {Message:lj} {NewLine}{Exception}"
              }
            },
            {
              "Name": "MSSqlServer",
              "Args": {
                "connectionString": "Server=localhost;Database=OrderManagementSystemDb;User Id=SA;Password=KeysightMay@24;Encrypt=true;TrustServerCertificate=True",
                "restrictedToMinimumLevel": "Information",
                "sinkOptionsSection": {
                  "tableName": "Logs",
                  "autoCreateSqlTable": true
                }
              }
            },
            {
              "Name": "Elasticsearch",
              "Args": {
                "nodeUris": "http://localhost:9200",
                "indexFormat": "ordersystem-logs-{0:yyyy.MM.dd}",
                "autoRegisterTemplate": true,
                "numberOfShards": 1,
                "numberOfReplicas": 1
              }
            }
          ]
        }
      }
    ],
    "Properties": {
      "Application": "App-OrderManagementAPI",
      "Server": "Server-125.08.13.1"
    }
  }
}
