## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/

# Visual Studio Code
.vscode/
*.code-workspace

# Rider
.idea/
*.sln.iml

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# NuGet Packages
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets

# The packages folder can be ignored because of Package Restore
**/packages/*
# except build/, which is used as an MSBuild target.
!**/packages/build/
# Uncomment if necessary however generally it should be regenerated
# !**/packages/repositories.config
# NuGet v3's project.json files makes some of the properties old csproj files inherit
# the rest null, so we null out the new properties into the old one for compatibility.
# A recent issue though means that things are never considered up to date
# with the old csproj file.
*.nuget.g.props
*.nuget.g.targets

# Misc
*.Cache
ClientBin/
~$*
*~
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
ServiceFabricBackup/
*.rptproj.bak

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptproj.rsuser

# Local test results
TestResults/

# Publish Web Publish Related
PublishProfiles/
*.azurePubxml
# Note: Comment the next line if you want to checkin your web deploy settings,
# but database connection strings and other sensitive data should be stored
# in protected profile files that are not checked into source control.
*.pubxml
*.publishproj

# Microsoft Azure Web App publish settings when a database gets included
*.PublishSettings

# Nuget personal access tokens
tokens.json

# Local user-specific files generated by Rider
.idea/shelf
.idea/tasks.xml
.idea/misc.xml

# Generated Dialogues (remove if you don't use it)
*.VC.db

# Python Tools for Visual Studio (PTVS)
__pycache__/
*.py[cod]_
*$py.class

# C++ objects and libs
*.slo
*.lo
*.o
*.a
*.lib

# Temporary User files
**/temp/
**/tmp/

# App Settings for local development
appsettings.Development.json
appsettings.Local.json

# Environment files
.env
.env.local

# Log files
*.log
